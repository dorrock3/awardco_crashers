      "tracks": {
        "torso": [{ "t": 0, "x": 0, "rot": 0 }, { "t": 80, "x": -14, "rot": -18 }, { "t": 220, "x": 0, "rot": 0 }],
        "arm_l": [{ "t": 0, "x": 0, "rot": 0 }, { "t": 80, "x": -14, "rot": -18 }, { "t": 220, "x": 0, "rot": 0 }],
        "arm_r": [{ "t": 0, "x": 0, "rot": 0 }, { "t": 80, "x": -14, "rot": -18 }, { "t": 220, "x": 0, "rot": 0 }]
      }
    },
    "jump": {
      "loop": false, "durationMs": 400,
      "tracks": {
        "torso": [{ "t": 0, "y": 0 }, { "t": 200, "y": -32 }, { "t": 400, "y": 0 }],
        "arm_l": [{ "t": 0, "y": 0 }, { "t": 200, "y": -32 }, { "t": 400, "y": 0 }],
        "arm_r": [{ "t": 0, "y": 0 }, { "t": 200, "y": -32 }, { "t": 400, "y": 0 }],
        "leg_l": [{ "t": 0, "y": 0 }, { "t": 200, "y": -22 }, { "t": 400, "y": 0 }],
        "leg_r": [{ "t": 0, "y": 0 }, { "t": 200, "y": -22 }, { "t": 400, "y": 0 }]
      }
    },
    "block": {
      "loop": true, "durationMs": 600,
      "tracks": {
        "torso": [{ "t": 0, "sx": 0.94, "sy": 0.94 }],
        "arm_l": [{ "t": 0, "sx": 0.94, "sy": 0.94 }],
        "arm_r": [{ "t": 0, "sx": 0.94, "sy": 0.94 }]
      }
    },
    "defeat": {
      "loop": false, "durationMs": 600,
      "tracks": {
        "torso": [{ "t": 0, "rot": 0 }, { "t": 600, "rot": 90 }],
        "arm_l": [{ "t": 0, "rot": 0 }, { "t": 600, "rot": 90 }],
        "arm_r": [{ "t": 0, "rot": 0 }, { "t": 600, "rot": 90 }],
        "leg_l": [{ "t": 0, "rot": 0 }, { "t": 600, "rot": 90 }],
        "leg_r": [{ "t": 0, "rot": 0 }, { "t": 600, "rot": 90 }]
      }
    }
  }
}
