        "arm_l": [{ "t": 0, "y": 0, "sx": 1, "sy": 1 }, { "t": 220, "y": -22, "sx": 1.12, "sy": 1.12 }, { "t": 760, "y": 0, "sx": 1, "sy": 1 }],
        "arm_r": [{ "t": 0, "y": 0, "sx": 1, "sy": 1 }, { "t": 220, "y": -22, "sx": 1.12, "sy": 1.12 }, { "t": 760, "y": 0, "sx": 1, "sy": 1 }]
